# Deny access to core directory
<IfModule mod_authz_core.c>
    Require all denied
</IfModule>

# Fallback for older Apache versions
Order Allow,Deny
Deny from all

# Prevent directory listing
Options -Indexes

# Block access to sensitive files
<FilesMatch "\.(htaccess|htpasswd|ini|log|sh|sql|bak|backup|old|tmp)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Block access to composer files
<FilesMatch "composer\.(json|lock)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Block access to environment files
<FilesMatch "\.env(\..*)?$">
    Order Allow,Deny
    Deny from all
</FilesMatch>
