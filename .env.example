# Environment Configuration
APP_NAME=KSP SaaS Koperasi Harian
APP_ENV=development
APP_KEY=base64:YourAppKeyHere
APP_DEBUG=true
APP_URL=http://localhost:8000

# Database Configuration
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ksp_saas
DB_USERNAME=root
DB_PASSWORD=

# Multi-Tenant Configuration
TENANT_DATABASE_PREFIX=ksp_
TENANT_ISOLATION=database
DEFAULT_TENANT=master

# Cache Configuration
CACHE_DRIVER=file
CACHE_PREFIX=ksp_
SESSION_DRIVER=file
SESSION_LIFETIME=120

# Queue Configuration
QUEUE_CONNECTION=database

# Mail Configuration
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@ksp-saas.com"
MAIL_FROM_NAME="${APP_NAME}"

# Security Configuration
BCRYPT_ROUNDS=12
JWT_SECRET=your-jwt-secret-key
JWT_TTL=3600
REFRESH_JWT_TTL=20160

# GPS & Geofencing
GEOFENCE_RADIUS=50
GPS_ACCURACY_THRESHOLD=10
FAKE_GPS_DETECTION=true

# Payment Gateway Configuration
QRIS_MERCHANT_ID=your-qrism-merchant-id
QRIS_CLIENT_KEY=your-qrism-client-key
QRIS_SECRET_KEY=your-qrism-secret-key
QRIS_ENVIRONMENT=sandbox

# Banking Integration
KOP_BANK_API_URL=https://api.kopbank.co.id
KOP_BANK_CLIENT_ID=your-kopbank-client-id
KOP_BANK_CLIENT_SECRET=your-kopbank-client-secret

# File Storage
FILESYSTEM_DRIVER=local
UPLOAD_PATH=uploads
MAX_FILE_SIZE=10240
ALLOWED_FILE_TYPES=jpg,jpeg,png,pdf,doc,docx

# Logging
LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
LOG_PATH=storage/logs

# API Configuration
API_RATE_LIMIT=1000
API_THROTTLE_REQUESTS=1000
API_THROTTLE_MINUTES=1

# Backup Configuration
BACKUP_DISK=local
BACKUP_PATH=backups
BACKUP_RETENTION_DAYS=30
AUTO_BACKUP_ENABLED=true

# WhatsApp Integration
WHATSAPP_API_URL=https://api.whatsapp.com
WHATSAPP_TOKEN=your-whatsapp-token
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-webhook-token

# Monitoring & Analytics
MONITORING_ENABLED=true
ERROR_TRACKING_ENABLED=true
PERFORMANCE_MONITORING_ENABLED=true

# Development Specific
DEBUGBAR_ENABLED=true
TELESCOPE_ENABLED=true
CLOCKWORK_ENABLED=true
