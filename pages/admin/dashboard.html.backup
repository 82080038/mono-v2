<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard Admin - KSP Lam Gabe Jaya</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="../../assets/css/dashboard-layout.css" rel="stylesheet">
    <link href="../../assets/css/dashboard.css" rel="stylesheet">
</head>

<body class="bg-light">
    <div class="dashboard-wrapper">
        <!-- Sticky Header -->
        <header class="dashboard-header navbar navbar-expand-lg navbar-dark bg-primary">
            <div class="container-fluid">
                <div class="d-flex align-items-center justify-content-between w-100">
                    <div class="d-flex align-items-center">
                        <!-- Mobile Menu Toggle -->
                        <button class="btn btn-link text-white mobile-menu-toggle d-lg-none me-3"
                            onclick="toggleSidebar()">
                            <i class="fas fa-bars"></i>
                        </button>

                        <!-- Logo/Brand -->
                        <a class="navbar-brand" href="../../index.html">
                            <i class="fas fa-building me-2"></i>
                            KSP Lam Gabe Jaya
                        </a>

                        <!-- Sidebar Toggle (Desktop) -->
                        <button class="btn btn-link text-white ms-3 d-none d-lg-block" onclick="toggleSidebarCollapse()"
                            title="Toggle Sidebar">
                            <i class="fas fa-outdent" id="sidebarToggleIcon"></i>
                        </button>
                    </div>

                    <!-- Center: Date/Time Display (Always Visible) -->
                    <div class="header-datetime-center text-white">
                        <span id="headerDateTime" class="fw-bold"></span>
                    </div>

                    <!-- Right: User Info (Desktop Only) -->
                    <div class="d-none d-xl-flex align-items-center gap-4 text-white">
                        <!-- User Info -->
                        <div class="header-user-info d-flex align-items-center gap-2">
                            <div class="text-end">
                                <div class="small fw-semibold" id="headerUserName">Loading...</div>
                                <div class="small text-white-50" id="headerUserRole">Loading...</div>
                            </div>
                            <div class="user-avatar bg-white bg-opacity-20 rounded-circle d-flex align-items-center justify-content-center"
                                style="width: 32px; height: 32px;">
                                <i class="fas fa-user text-white small"></i>
                            </div>
                        </div>
                    </div>

                    <!-- Mobile User Info Only -->
                    <div class="d-flex d-xl-none align-items-center">
                        <div class="text-end text-white me-2">
                            <div class="small fw-semibold d-none d-md-block" id="headerUserNameMobile">Loading...</div>
                        </div>
                        <div class="user-avatar bg-white bg-opacity-20 rounded-circle d-flex align-items-center justify-content-center"
                            style="width: 32px; height: 32px;">
                            <i class="fas fa-user text-white small"></i>
                        </div>
                    </div>
                </div>
            </div>
        </header>

        <!-- Content Area: Sidebar + Main with independent scroll -->
        <div class="dashboard-content">
            <!-- Sidebar -->
            <aside class="dashboard-sidebar" id="dashboardSidebar">
                <div class="sidebar-header">
                    <h6 class="mb-0 text-muted">Menu Admin</h6>
                </div>
                <nav class="sidebar-nav">
                    <ul class="nav flex-column" id="sidebarMenu"></ul>
                </nav>
            </aside>

            <!-- Main Content Area -->
            <main class="dashboard-main">
                <!-- Main Content (scrollable) -->
                <div class="main-content" id="mainContentRoot">
                    <!-- Filter & Search Bar -->
                    <div class="dashboard-card mb-4">
                        <div class="card-body d-flex flex-column flex-lg-row align-items-lg-center gap-3">
                            <div class="flex-grow-1">
                                <div class="input-group">
                                    <span class="input-group-text"><i class="fas fa-search"></i></span>
                                    <input type="text" class="form-control" placeholder="Cari nama / ID / email"
                                        aria-label="Pencarian">
                                </div>
                            </div>
                            <div class="d-flex gap-2 flex-wrap">
                                <select class="form-select form-select-sm" aria-label="Periode">
                                    <option value="today">Hari ini</option>
                                    <option value="week">Minggu ini</option>
                                    <option value="month" selected>Bulan ini</option>
                                    <option value="custom">Custom</option>
                                </select>
                                <select class="form-select form-select-sm" aria-label="Status">
                                    <option value="all" selected>Semua status</option>
                                    <option value="active">Aktif</option>
                                    <option value="pending">Pending</option>
                                    <option value="overdue">Terlambat</option>
                                </select>
                                <button class="btn btn-outline-secondary btn-sm">Reset filter</button>
                            </div>
                        </div>
                        <div class="card-body pt-0">
                            <div class="d-flex align-items-center flex-wrap gap-2" id="activeFilters">
                                <span class="badge rounded-pill text-bg-light border">Periode: Bulan ini</span>
                                <span class="badge rounded-pill text-bg-light border">Status: Semua</span>
                                <button class="btn btn-link btn-sm text-decoration-none">Clear all</button>
                            </div>
                        </div>
                    </div>

                    <!-- Data Table Placeholder -->
                    <div class="dashboard-card mb-4">
                        <div class="card-header d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="mb-0">Ringkasan Data</h6>
                                <small class="text-muted">Tabel dengan paginasi & aksi massal</small>
                            </div>
                            <div class="d-flex gap-2">
                                <button class="btn btn-sm btn-outline-primary"><i
                                        class="fas fa-plus me-1"></i>Tambah</button>
                                <button class="btn btn-sm btn-outline-secondary"><i
                                        class="fas fa-file-export me-1"></i>Export</button>
                            </div>
                        </div>
                        <div class="card-body p-0">
                            <div class="table-responsive">
                                <table class="table align-middle mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th scope="col"><input type="checkbox" aria-label="Select all"></th>
                                            <th scope="col">Nama</th>
                                            <th scope="col">ID</th>
                                            <th scope="col">Status</th>
                                            <th scope="col">Tanggal</th>
                                            <th scope="col" class="text-end">Aksi</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr>
                                            <td><input type="checkbox" aria-label="Select row"></td>
                                            <td>Contoh Data</td>
                                            <td>#123456</td>
                                            <td><span class="badge bg-success">Aktif</span></td>
                                            <td>2024-01-15</td>
                                            <td class="text-end">
                                                <div class="btn-group btn-group-sm" role="group">
                                                    <button class="btn btn-outline-secondary"><i
                                                            class="fas fa-eye"></i></button>
                                                    <button class="btn btn-outline-secondary"><i
                                                            class="fas fa-edit"></i></button>
                                                    <button class="btn btn-outline-secondary"><i
                                                            class="fas fa-ellipsis-v"></i></button>
                                                </div>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td><input type="checkbox" aria-label="Select row"></td>
                                            <td>Data Kedua</td>
                                            <td>#123457</td>
                                            <td><span class="badge bg-warning text-dark">Pending</span></td>
                                            <td>2024-01-18</td>
                                            <td class="text-end">
                                                <div class="btn-group btn-group-sm" role="group">
                                                    <button class="btn btn-outline-secondary"><i
                                                            class="fas fa-eye"></i></button>
                                                    <button class="btn btn-outline-secondary"><i
                                                            class="fas fa-edit"></i></button>
                                                    <button class="btn btn-outline-secondary"><i
                                                            class="fas fa-ellipsis-v"></i></button>
                                                </div>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td><input type="checkbox" aria-label="Select row"></td>
                                            <td>Data Ketiga</td>
                                            <td>#123458</td>
                                            <td><span class="badge bg-danger">Terlambat</span></td>
                                            <td>2024-01-20</td>
                                            <td class="text-end">
                                                <div class="btn-group btn-group-sm" role="group">
                                                    <button class="btn btn-outline-secondary"><i
                                                            class="fas fa-eye"></i></button>
                                                    <button class="btn btn-outline-secondary"><i
                                                            class="fas fa-edit"></i></button>
                                                    <button class="btn btn-outline-secondary"><i
                                                            class="fas fa-ellipsis-v"></i></button>
                                                </div>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                        <div class="card-footer d-flex flex-wrap justify-content-between align-items-center gap-2">
                            <div class="d-flex align-items-center gap-2">
                                <span class="text-muted small">Menampilkan 1-3 dari 1.234 data</span>
                            </div>
                            <div class="d-flex align-items-center gap-2">
                                <select class="form-select form-select-sm" aria-label="Page size" style="width: auto;">
                                    <option>10</option>
                                    <option selected>25</option>
                                    <option>50</option>
                                    <option>100</option>
                                </select>
                                <nav aria-label="Pagination">
                                    <ul class="pagination pagination-sm mb-0">
                                        <li class="page-item disabled"><span class="page-link">Prev</span></li>
                                        <li class="page-item active"><span class="page-link">1</span></li>
                                        <li class="page-item"><span class="page-link">2</span></li>
                                        <li class="page-item"><span class="page-link">3</span></li>
                                        <li class="page-item"><span class="page-link">Next</span></li>
                                    </ul>
                                </nav>
                            </div>
                        </div>
                    </div>
                    <!-- Stats Cards -->
                    <div class="row mb-4" id="dashboardStats">
                        <div class="col-xl-3 col-sm-6 mb-4">
                            <div class="dashboard-card">
                                <div class="card-body d-flex align-items-center">
                                    <div class="flex-shrink-0 me-3">
                                        <div class="icon-circle bg-primary text-white">
                                            <i class="fas fa-users"></i>
                                        </div>
                                    </div>
                                    <div>
                                        <h6 class="text-uppercase text-muted mb-1">Total Anggota</h6>
                                        <h3 class="mb-0" id="totalMembers">-</h3>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-xl-3 col-sm-6 mb-4">
                            <div class="dashboard-card">
                                <div class="card-body d-flex align-items-center">
                                    <div class="flex-shrink-0 me-3">
                                        <div class="icon-circle bg-success text-white">
                                            <i class="fas fa-hand-holding-usd"></i>
                                        </div>
                                    </div>
                                    <div>
                                        <h6 class="text-uppercase text-muted mb-1">Pinjaman Aktif</h6>
                                        <h3 class="mb-0" id="activeLoans">-</h3>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-xl-3 col-sm-6 mb-4">
                            <div class="dashboard-card">
                                <div class="card-body d-flex align-items-center">
                                    <div class="flex-shrink-0 me-3">
                                        <div class="icon-circle bg-warning text-white">
                                            <i class="fas fa-piggy-bank"></i>
                                        </div>
                                    </div>
                                    <div>
                                        <h6 class="text-uppercase text-muted mb-1">Total Simpanan</h6>
                                        <h3 class="mb-0" id="totalSavings">-</h3>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-xl-3 col-sm-6 mb-4">
                            <div class="dashboard-card">
                                <div class="card-body d-flex align-items-center">
                                    <div class="flex-shrink-0 me-3">
                                        <div class="icon-circle bg-danger text-white">
                                            <i class="fas fa-exchange-alt"></i>
                                        </div>
                                    </div>
                                    <div>
                                        <h6 class="text-uppercase text-muted mb-1">Transaksi Hari Ini</h6>
                                        <h3 class="mb-0" id="todayTransactions">-</h3>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Charts Row -->
                    <div class="row mb-4">
                        <div class="col-xl-8 col-lg-7">
                            <div class="dashboard-card">
                                <div class="card-header d-flex justify-content-between align-items-center">
                                    <h6 class="mb-0">Pertumbuhan Anggota</h6>
                                    <i class="fas fa-ellipsis-v text-muted"></i>
                                </div>
                                <div class="card-body">
                                    <canvas id="growthChart" height="120"></canvas>
                                </div>
                            </div>
                        </div>
                        <div class="col-xl-4 col-lg-5">
                            <div class="dashboard-card">
                                <div class="card-header d-flex justify-content-between align-items-center">
                                    <h6 class="mb-0">Distribusi Anggota</h6>
                                    <i class="fas fa-ellipsis-v text-muted"></i>
                                </div>
                                <div class="card-body">
                                    <canvas id="memberChart" height="120"></canvas>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Recent Activity & Reminders -->
                    <div class="row">
                        <div class="col-xl-6">
                            <div class="dashboard-card">
                                <div class="card-header">
                                    <h6 class="mb-0">Aktivitas Terbaru</h6>
                                </div>
                                <div class="card-body">
                                    <div class="list-group">
                                        <a href="#" class="list-group-item list-group-item-action">
                                            <div class="d-flex w-100 justify-content-between">
                                                <h6 class="mb-1">Pendaftaran anggota baru</h6>
                                                <small class="text-muted">3 menit lalu</small>
                                            </div>
                                            <p class="mb-1">Andi Setiawan bergabung sebagai anggota.</p>
                                            <small class="text-muted">Admin</small>
                                        </a>
                                        <a href="#" class="list-group-item list-group-item-action">
                                            <div class="d-flex w-100 justify-content-between">
                                                <h6 class="mb-1">Persetujuan pinjaman</h6>
                                                <small class="text-muted">10 menit lalu</small>
                                            </div>
                                            <p class="mb-1">Pinjaman sebesar Rp 5.000.000 disetujui.</p>
                                            <small class="text-muted">Officer</small>
                                        </a>
                                        <a href="#" class="list-group-item list-group-item-action">
                                            <div class="d-flex w-100 justify-content-between">
                                                <h6 class="mb-1">Pembayaran angsuran</h6>
                                                <small class="text-muted">30 menit lalu</small>
                                            </div>
                                            <p class="mb-1">Pembayaran angsuran dari Budi Santoso.</p>
                                            <small class="text-muted">Kasir</small>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-xl-6">
                            <div class="dashboard-card">
                                <div class="card-header">
                                    <h6 class="mb-0">Pengingat</h6>
                                </div>
                                <div class="card-body">
                                    <ul class="list-unstyled mb-0">
                                        <li class="mb-3">
                                            <i class="fas fa-bell text-warning me-2"></i>
                                            12 pinjaman jatuh tempo minggu ini
                                        </li>
                                        <li class="mb-3">
                                            <i class="fas fa-user-clock text-info me-2"></i>
                                            8 anggota belum melengkapi dokumen
                                        </li>
                                        <li class="mb-3">
                                            <i class="fas fa-clipboard-check text-success me-2"></i>
                                            5 pengajuan pinjaman menunggu review
                                        </li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </main>
        </div>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <!-- Configuration -->
    <script src="../../assets/js/config.js"></script>
    <!-- Fixed Authentication -->
    <script src="../../assets/js/auth-fixed.js"></script>
    <!-- Dashboard JS (optional, can be re-enabled later) -->
    <!-- <script src="../../assets/js/dashboard.js"></script> -->

    <script>
        // Dynamic content loader for main-content area
        (function () {
            let pageMap = {};
            let menuItems = [];

            const mainContentEl = document.querySelector('#mainContentRoot');
            const sidebarMenu = document.getElementById('sidebarMenu');

            // Save initial dashboard content for restore
            const initialContent = mainContentEl ? mainContentEl.innerHTML : '';

            if (!mainContentEl || !sidebarMenu) return;

            function setActive(link) {
                sidebarMenu.querySelectorAll('.nav-link').forEach(a => a.classList.remove('active'));
                if (link) link.classList.add('active');
            }

            async function loadPage(pageKey, linkEl) {
                const url = pageMap[pageKey];
                if (!url) {
                    renderFallback(`Halaman untuk "${pageKey}" belum tersedia.`);
                    setActive(linkEl);
                    return;
                }

                try {
                    const resp = await fetch(url, { cache: 'no-cache' });
                    if (!resp.ok) throw new Error(`Status ${resp.status}`);
                    const html = await resp.text();
                    const fragment = extractContent(html);
                    mainContentEl.innerHTML = fragment || html;
                    setActive(linkEl);
                    window.scrollTo({ top: 0, behavior: 'smooth' });
                } catch (err) {
                    renderFallback(`Gagal memuat halaman: ${err.message}`);
                    setActive(linkEl);
                }
            }

            function extractContent(html) {
                const parser = new DOMParser();
                const doc = parser.parseFromString(html, 'text/html');

                // Try multiple selectors for better compatibility
                const container = doc.querySelector('main') ||
                    doc.querySelector('.container') ||
                    doc.querySelector('.card') ||
                    doc.querySelector('body');

                if (container) {
                    // If we got body, return innerHTML excluding scripts
                    if (container.tagName === 'BODY') {
                        const tempDiv = document.createElement('div');
                        tempDiv.innerHTML = container.innerHTML;
                        // Remove scripts for security
                        tempDiv.querySelectorAll('script').forEach(script => script.remove());
                        return tempDiv.innerHTML;
                    }
                    return container.innerHTML;
                }
                return '';
            }

            function renderFallback(message) {
                mainContentEl.innerHTML = `
                    <div class="alert alert-warning mb-3">
                        <i class="fas fa-info-circle me-2"></i>${message}
                    </div>
                `;
            }

            // Bind sidebar links
            sidebarMenu.querySelectorAll('a[data-page]').forEach(link => {
                link.addEventListener('click', (e) => {
                    e.preventDefault();
                    const pageKey = link.getAttribute('data-page');
                    if (pageKey === 'dashboard') {
                        mainContentEl.innerHTML = initialContent;
                        setActive(link);
                        window.scrollTo({ top: 0, behavior: 'smooth' });
                        return;
                    }
                    loadPage(pageKey, link);
                });
            });

            function getRoleKey() {
                try {
                    const stored = localStorage.getItem('userData') || sessionStorage.getItem('userData');
                    if (stored) {
                        const parsed = JSON.parse(stored);
                        return parsed.role || 'admin';
                    }
                } catch (e) { }
                return 'admin';
            }

            async function loadMenu() {
                try {
                    const resp = await fetch('../../assets/config/menus.json', { cache: 'no-cache' });
                    const json = await resp.json();
                    const roleKey = getRoleKey();
                    menuItems = (json && json[roleKey]) || (json && json.admin) || [];
                } catch (e) {
                    // fallback jika fetch gagal
                    menuItems = [
                        { key: 'dashboard', title: 'Dashboard', icon: 'fas fa-tachometer-alt' }
                    ];
                }

                renderMenu(menuItems);
                bindMenuEvents();
            }

            function renderMenu(items) {
                pageMap = {};
                sidebarMenu.innerHTML = items.map(item => {
                    if (item.key === 'divider') {
                        return `<li class="nav-item"><hr class="my-2"></li>`;
                    }

                    const icon = item.icon || 'fas fa-circle';
                    const active = item.key === 'dashboard' ? 'active' : '';
                    const url = item.url || `${item.key}.html`;
                    const cssClass = item.class || '';
                    const onclick = item.onclick || '';

                    pageMap[item.key] = url;
                    return `
                        <li class="nav-item">
                            <a class="nav-link ${active} ${cssClass}" href="#" data-page="${item.key}" ${onclick ? `onclick="${onclick}"` : ''}>
                                <i class="${icon} me-2"></i>
                                <span>${item.title}</span>
                            </a>
                        </li>
                    `;
                }).join('');
            }

            function bindMenuEvents() {
                sidebarMenu.querySelectorAll('a[data-page]').forEach(link => {
                    link.addEventListener('click', (e) => {
                        e.preventDefault();
                        const pageKey = link.getAttribute('data-page');

                        // Auto-close sidebar on mobile after menu click
                        if (window.innerWidth < 992) {
                            const sidebar = document.getElementById('dashboardSidebar');
                            sidebar.classList.remove('show');
                        }

                        if (pageKey === 'dashboard') {
                            mainContentEl.innerHTML = initialContent;
                            setActive(link);
                            window.scrollTo({ top: 0, behavior: 'smooth' });
                            return;
                        }
                        loadPage(pageKey, link);
                    });
                });
            }

            window.toggleSidebar = function () {
                const sidebar = document.getElementById('dashboardSidebar');
                sidebar.classList.toggle('show');
            };

            window.toggleSidebarCollapse = function () {
                const sidebar = document.getElementById('dashboardSidebar');
                const icon = document.getElementById('sidebarToggleIcon');
                sidebar.classList.toggle('collapsed');
                icon.className = sidebar.classList.contains('collapsed') ? 'fas fa-indent' : 'fas fa-outdent';
            };

            // Sync user name with sidebar and header
            function updateSidebarUserName() {
                const sidebarUserName = document.getElementById('sidebarUserName');
                const headerUserName = document.getElementById('headerUserName');
                const headerUserRole = document.getElementById('headerUserRole');
                const headerUserNameMobile = document.getElementById('headerUserNameMobile');

                // Try to get user name from localStorage or sessionStorage
                try {
                    const userData = localStorage.getItem('userData') || sessionStorage.getItem('userData');
                    if (userData) {
                        const parsed = JSON.parse(userData);
                        const userName = parsed.name || 'Administrator';
                        const userRole = parsed.role || 'admin';
                        const formattedRole = userRole.charAt(0).toUpperCase() + userRole.slice(1);

                        // Update sidebar
                        if (sidebarUserName) {
                            sidebarUserName.textContent = userName;
                        }

                        // Update header (desktop)
                        if (headerUserName) {
                            headerUserName.textContent = userName;
                        }
                        if (headerUserRole) {
                            headerUserRole.textContent = formattedRole;
                        }

                        // Update header (mobile)
                        if (headerUserNameMobile) {
                            headerUserNameMobile.textContent = userName;
                        }
                    }
                } catch (e) {
                    // Fallback to default
                    const defaultName = 'Administrator';
                    const defaultRole = 'Admin';

                    if (sidebarUserName) {
                        sidebarUserName.textContent = defaultName;
                    }
                    if (headerUserName) {
                        headerUserName.textContent = defaultName;
                    }
                    if (headerUserRole) {
                        headerUserRole.textContent = defaultRole;
                    }
                    if (headerUserNameMobile) {
                        headerUserNameMobile.textContent = defaultName;
                    }
                }
            }

            // Update date and time display
            function updateDateTime() {
                const dateTimeElement = document.getElementById('headerDateTime');
                if (dateTimeElement) {
                    const now = new Date();

                    // Format day name in Indonesian
                    const days = ['Minggu', 'Senin', 'Selasa', 'Rabu', 'Kamis', 'Jumat', 'Sabtu'];
                    const dayName = days[now.getDay()];

                    // Format date
                    const day = now.getDate().toString().padStart(2, '0');
                    const month = (now.getMonth() + 1).toString().padStart(2, '0');
                    const year = now.getFullYear();

                    // Format time (24-hour)
                    const hours = now.getHours().toString().padStart(2, '0');
                    const minutes = now.getMinutes().toString().padStart(2, '0');
                    const seconds = now.getSeconds().toString().padStart(2, '0');

                    const formattedDateTime = `${dayName}, ${day}-${month}-${year} | ${hours}:${minutes}:${seconds}`;
                    dateTimeElement.textContent = formattedDateTime;
                }
                // Load dashboard data
                async function loadDashboardData() {
                    try {
                        // Load members data
                        const membersResponse = await fetch('../../api/members.php?action=get_members&limit=1');
                        const membersResult = await membersResponse.json();
                        if (membersResult.success) {
                            document.getElementById('totalMembers').textContent = membersResult.data.pagination.total.toLocaleString('id-ID');
                        }

                        // Load loans data
                        const loansResponse = await fetch('../../api/loans.php?action=get_loans&limit=1');
                        const loansResult = await loansResponse.json();
                        if (loansResult.success) {
                            const activeLoans = loansResult.data.data.filter(loan => ['Active', 'Late'].includes(loan.status)).length;
                            document.getElementById('activeLoans').textContent = activeLoans.toLocaleString('id-ID');
                        }

                        // Load accounts data for total savings
                        const accountsResponse = await fetch('../../api/savings.php?action=get_accounts&limit=1');
                        const accountsResult = await accountsResponse.json();
                        if (accountsResult.success) {
                            const totalSavings = accountsResult.data.data.reduce((sum, account) => sum + parseFloat(account.balance || 0), 0);
                            document.getElementById('totalSavings').textContent = 'Rp ' + formatCurrency(totalSavings);
                        }

                        // Load today's transactions
                        const today = new Date().toISOString().split('T')[0];
                        const transactionsResponse = await fetch(`../../api/savings.php?action=get_transactions&account_id=1&start_date=${today}&end_date=${today}&limit=1`);
                        const transactionsResult = await transactionsResponse.json();
                        if (transactionsResult.success) {
                            document.getElementById('todayTransactions').textContent = transactionsResult.data.pagination.total.toLocaleString('id-ID');
                        }

                    } catch (error) {
                        console.error('Error loading dashboard data:', error);
                        // Set default values on error
                        document.getElementById('totalMembers').textContent = '0';
                        document.getElementById('activeLoans').textContent = '0';
                        document.getElementById('totalSavings').textContent = 'Rp 0';
                        document.getElementById('todayTransactions').textContent = '0';
                    }
                }

                // Format currency helper
                function formatCurrency(amount) {
                    return parseInt(amount || 0).toLocaleString('id-ID');
                }

                // Initialize dashboard
                document.addEventListener('DOMContentLoaded', function () {
                    loadMenu();
                    updateSidebarUserName();
                    updateDateTime();
                    setInterval(updateDateTime, 1000);

                    // Load dashboard data
                    loadDashboardData();

                    // Refresh dashboard data every 30 seconds
                    setInterval(loadDashboardData, 30000);
                });

                // Initialize header functions
                function initializeHeader() {
                    updateSidebarUserName();
                    updateDateTime();

                    // Update time every second
                    setInterval(updateDateTime, 1000);

                    // Listen for storage changes (for multi-tab sync)
                    window.addEventListener('storage', function (e) {
                        if (e.key === 'userData' || e.key === 'sessionStorage') {
                            updateSidebarUserName();
                        }
                    });
                }

                // Update user name when page loads
                updateSidebarUserName();

                // Initialize header when DOM is ready
                if (document.readyState === 'loading') {
                    document.addEventListener('DOMContentLoaded', initializeHeader);
                } else {
                    initializeHeader();
                }

                // Handle window resize for mobile/desktop transitions
                window.addEventListener('resize', function () {
                    if (window.innerWidth >= 992) {
                        // Desktop mode - ensure sidebar is visible
                        const sidebar = document.getElementById('dashboardSidebar');
                        sidebar.classList.remove('show');
                    }
                });

                // Missing functions for menu items
                window.showProfile = function () {
                    // Show profile modal or navigate to profile page
                    alert('Fitur Profil akan segera tersedia');
                };

                window.showSettings = function () {
                    // Show settings modal or navigate to settings page
                    alert('Fitur Pengaturan akan segera tersedia');
                };

                window.logout = function () {
                    // Handle logout
                    if (confirm('Apakah Anda yakin ingin keluar?')) {
                        // Clear session data
                        localStorage.removeItem('userData');
                        sessionStorage.removeItem('userData');

                        // Redirect to login page using BASE_PATH
                        const loginUrl = window.buildUrl ? window.buildUrl('login.html') : '../../login.html';
                        window.location.href = loginUrl;
                    }
                };

                loadMenu();
            });
    </script>
</body>

</html>