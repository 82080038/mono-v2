# Only ignore truly unnecessary files for development
# Keep all application files for development on other computers

# Temporary files
*.tmp
*.temp
temp/
tmp/

# OS specific files
.DS_Store
Thumbs.db
desktop.ini

# Editor files
*.swp
*.swo
*~

# Node modules (if any)
node_modules/

# Build artifacts (if any)
build/
dist/

# Large binary files that should be handled separately
*.exe
*.dmg
*.pkg
*.deb
*.rpm

# Keep all application files for development:
# - All PHP files
# - All database files
# - All configuration files
# - All documentation
# - All assets
# - All uploads (for development)
# - All logs (for debugging)
# - All backup files (for development reference)
# - All original files (for development reference)
